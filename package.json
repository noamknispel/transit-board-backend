{
  "name": "transit-board",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:backend": "cd apps/backend && ~/.bun/bin/bun --watch src/index.ts",
    "start:backend": "cd apps/backend && ~/.bun/bin/bun src/index.ts",
    "import:gtfs": "cd apps/backend && ~/.bun/bin/bun src/cli/import-gtfs.ts"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
